# Configuration Exemple - Copier et adapter
PORT=5000

# Base de données
DB_HOST=localhost
DB_USER=votre_db_user
DB_PASSWORD=votre_db_password
DB_NAME=labelia_prod
DATABASE_URL=mysql://votre_db_user:votre_db_password@localhost:3306/labelia_prod

# JWT Secret (IMPORTANT: générer un secret de 256 bits minimum)
JWT_SECRET=votre_jwt_secret_256_bits_minimum_pour_securite

# Configuration Cloudinary (OBLIGATOIRE pour les uploads d'images)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Exemple:
# CLOUDINARY_URL=cloudinary://891115623374645:votre_secret_ici@dy5yusdni

# URLs de l'application
API_URL=https://api.labelia.com
FRONTEND_URL=https://labelia.com
